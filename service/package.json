{
  "name": "xarji-service",
  "version": "1.0.0",
  "description": "xarji — Finance manager for Georgian banks (service)",
  "type": "module",
  "scripts": {
    "setup": "bun run src/setup.ts",
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "install-service": "bun run src/cli.ts install",
    "uninstall-service": "bun run src/cli.ts uninstall",
    "status": "bun run src/cli.ts status",
    "test-parse": "bun run src/cli.ts test",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build:embed": "bun run ../scripts/embed-assets.ts",
    "build:binary": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile dist/xarji"
  },
  "dependencies": {
    "@instantdb/admin": "latest",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "~5.9"
  }
}
